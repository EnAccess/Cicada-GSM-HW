	)
	(gr_text "- 2 layer FR-4\n- 1oz outer copper\n- total finished thickness: 1.6mm±0.2mm\n- Green solder mask\n- White text\n\n\nImpedance controlleed 50R SE lines:\nCo-planar line, to be more independent of stackup.\nW=0.55mm\nS=0.16mm\nH=1.5mm\nEr = 4.5 - 4.7, but can prob be wider\n"
		(at 157.02 77.69 0)
		(layer "Cmts.User")
		(uuid "a2865e0f-19fc-4d7b-8943-dc919ced495a")
		(effects
			(font
				(size 1.5 1.5)
				(thickness 0.2)
			)
			(justify left)
		)
	)
	(gr_text "~0.2R copper trace snaky.\n\nWe want to prevent current spikes from propagating\nto the host side.\n\nSnake is more robust than a resistor, think hot-plug\ninrush current."
		(at 159.7 63.8 0)
		(layer "Eco1.User")
		(uuid "0920a9a1-5498-4e47-b922-ddc75df9505e")
		(effects
			(font
				(size 1 1)
				(thickness 0.15)
			)
			(justify left)
		)
	)
